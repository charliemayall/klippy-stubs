class MCUConfigHelper:
    def __init__(
        self, config: configfile.ConfigWrapper, conn_helper: MCUConnectHelper
    ) -> None: ...
    def is_config_finalized(self) -> bool: ...
    @overload
    def setup_pin(
        self, pin_type: Literal["endstop"], pin_params: PinParams
    ) -> MCU_endstop: ...
    @overload
    def setup_pin(
        self, pin_type: Literal["digital_out"], pin_params: PinParams
    ) -> MCU_digital_out: ...
    @overload
    def setup_pin(self, pin_type: Literal["pwm"], pin_params: PinParams) -> MCU_pwm: ...
    @overload
    def setup_pin(self, pin_type: Literal["adc"], pin_params: PinParams) -> MCU_adc: ...
    def create_oid(self) -> int: ...
    def register_config_callback(self, cb: Callable[[], None]) -> None: ...
    def add_config_cmd(
        self, cmd: str, is_init: bool = False, on_restart: bool = False
    ) -> None: ...
    def register_post_init_callback(self, cb: Callable[[], None]) -> None: ...
    def get_query_slot(self, oid: int) -> int: ...
    def seconds_to_clock(self, time: float) -> int: ...
    def request_move_queue_slot(self) -> None: ...

class MCU:
    error = error
    def __init__(
        self, config: configfile.ConfigWrapper, clocksync: ClockSync
    ) -> None: ...
    def get_name(self) -> str: ...
    def get_printer(self) -> Printer: ...
    def is_fileoutput(self) -> bool: ...
    @overload
    def setup_pin(
        self, pin_type: Literal["endstop"], pin_params: PinParams
    ) -> MCU_endstop: ...
    @overload
    def setup_pin(
        self, pin_type: Literal["digital_out"], pin_params: PinParams
    ) -> MCU_digital_out: ...
    @overload
    def setup_pin(self, pin_type: Literal["pwm"], pin_params: PinParams) -> MCU_pwm: ...
    @overload
    def setup_pin(self, pin_type: Literal["adc"], pin_params: PinParams) -> MCU_adc: ...
    def create_oid(self) -> int: ...
    def register_config_callback(self, cb: Callable[[], None]) -> None: ...
    def add_config_cmd(
        self, cmd: str, is_init: bool = False, on_restart: bool = False
    ) -> None: ...
    def request_move_queue_slot(self) -> None: ...
    def get_query_slot(self, oid: int) -> int: ...
    def seconds_to_clock(self, time: float) -> int: ...
    def min_schedule_time(self) -> float: ...
    def max_nominal_duration(self) -> float: ...
    def lookup_command(self, msgformat: str, cq=None) -> CommandWrapper: ...
    def lookup_query_command(
        self,
        msgformat: str,
        respformat: str,
        oid: int | None = None,
        cq=None,
        is_async: bool = False,
    ) -> CommandQueryWrapper: ...
    def try_lookup_command(self, msgformat: str) -> CommandWrapper | None: ...
    def alloc_command_queue(self) -> Incomplete: ...
    def register_serial_response(
        self, cb: Callable[[dict[str, Any]], None], msg: str, oid: int | None = None
    ) -> AsyncResponseWrapper: ...
    def check_valid_response(self, msgformat: str) -> None: ...
    def get_enumerations(self) -> dict[str, dict[int, str]]: ...
    def get_constants(self) -> dict[str, Any]: ...
    def get_constant_float(self, name: str) -> float: ...
    def print_time_to_clock(self, print_time: float) -> int: ...
    def clock_to_print_time(self, clock: int) -> float: ...
    def estimated_print_time(self, eventtime: float) -> float: ...
    def clock32_to_clock64(self, clock32: int) -> int: ...
    def calibrate_clock(
        self, print_time: float, eventtime: float
    ) -> tuple[float, float]: ...
    def get_status(self, eventtime: float | None = None) -> dict[str, Any]: ...
    def stats(self, eventtime: float) -> tuple[bool, str]: ...

def add_printer_objects(config: configfile.ConfigWrapper) -> None: ...
def get_printer_mcu(printer: Printer, name: str) -> MCU: ...
