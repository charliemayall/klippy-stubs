class error(Exception): ...

MIN_SCHEDULE_TIME: float
MAX_SCHEDULE_TICKS: int
MAX_NOMINAL_DURATION: float

class DummyResponse:
    def __init__(self, serial, name: str, oid: int | None = None) -> None: ...
    def get_response(
        self, cmds, cmd_queue, minclock: int = 0, reqclock: int = 0, retry: bool = True
    ) -> dict[str, Any]: ...

class RetryAsyncCommand:
    TIMEOUT_TIME: float
    RETRY_TIME: float
    serial: SerialReader
    name: str
    oid: int | None
    reactor: Incomplete
    completion: ReactorCompletion
    min_query_time: float
    need_response: bool
    def __init__(self, serial, name: str, oid: int | None = None) -> None: ...
    def handle_callback(self, params: dict[str, Any]) -> None: ...
    def get_response(
        self, cmds, cmd_queue, minclock: int = 0, reqclock: int = 0, retry: bool = True
    ) -> dict[str, Any]: ...

class CommandQueryWrapper:
    def __init__(
        self,
        conn_helper,
        msgformat: str,
        respformat: str,
        oid: int | None = None,
        cmd_queue=None,
        is_async: bool = False,
    ) -> None: ...
    def send(
        self,
        data: tuple[Any, ...] = (),
        minclock: int = 0,
        reqclock: int = 0,
        retry: bool = True,
    ) -> dict[str, Any]: ...
    def send_with_preface(
        self,
        preface_cmd,
        preface_data: tuple[Any, ...] = (),
        data: tuple[Any, ...] = (),
        minclock: int = 0,
        reqclock: int = 0,
        retry: bool = True,
    ) -> dict[str, Any]: ...

class CommandWrapper:
    def __init__(self, conn_helper, msgformat: str, cmd_queue=None) -> None: ...
    def send(
        self, data: tuple[Any, ...] = (), minclock: int = 0, reqclock: int = 0
    ) -> None: ...
    def send_wait_ack(
        self, data: tuple[Any, ...] = (), minclock: int = 0, reqclock: int = 0
    ) -> None: ...
    def get_command_tag(self) -> int: ...

class AsyncResponseWrapper:
    def __init__(
        self,
        conn_helper,
        cfg_helper,
        callback: Callable[[dict[str, Any]], None],
        msgformat: str,
        oid: int | None = None,
    ) -> None: ...
    def unregister(self) -> None: ...

